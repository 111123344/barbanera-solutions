# Supabase (required for real-time translation sync)
# 1. Go to https://supabase.com and create a free account
# 2. Create a new project
# 3. Go to Project Settings > API
# 4. Copy the Project URL and anon/public key below

NEXT_PUBLIC_SUPABASE_URL=https://your-project-id.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-public-key

# MyMemory Translation API (optional)
# Register at https://mymemory.translated.net/doc/spec.php
# to increase from 1,000 to 10,000 translated words/day (free)
MYMEMORY_EMAIL=your@email.com
